LIVEKIT_URL=wss://your-livekit-host
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
OPENAI_API_KEY=

# Stream bundled res/static_share.png instead of live tmux (default on if file exists).
# Set TMUX_STREAM_STATIC_PNG=0 to show the real terminal again.
# TMUX_STREAM_STATIC_PNG=1
# TMUX_STATIC_IMAGE=/absolute/or/relative/path/to/screenshot.png
# Video pipeline: 1 = simple RGBA + minimal publish opts
# (default 1280×720, 16:9 widescreen). 0 = advanced.
# TMUX_COMPAT_VIDEO=1
# TMUX_COMPAT_WIDTH=1280
# TMUX_COMPAT_HEIGHT=720
# Compat track: camera (default, matches video_play.py) or screenshare.
# TMUX_COMPAT_TRACK_SOURCE=camera
# RGBA→I420 before publish (default 1; helps striping/corruption).
# TMUX_COMPAT_I420=1
# Dump first frame to /tmp/tmux_debug_first.rgba for ffplay verification.
# TMUX_DEBUG_RAW=1

# tmux session to attach to (created if missing)
TMUX_SESSION_NAME=agent

# terminal grid & render settings (optional)
TMUX_COLS=100
TMUX_ROWS=30
TMUX_FONT_SIZE=20
TMUX_FPS=10
TMUX_MAX_BITRATE=8000000
# Video: letterbox terminal to this size before encode (default 1280x720 — avoids odd-width encoder bugs)
# TMUX_OUT_WIDTH=1280
# TMUX_OUT_HEIGHT=720
# Published codec: vp8 | h264 | vp9 | av1 (default h264)
# TMUX_VIDEO_CODEC=h264
# Publish as screenshare or camera track if the client mishandles one (default screenshare)
# TMUX_TRACK_SOURCE=screenshare
# Optional: RGB24 → I420 before capture_frame (default 0 — publish RGB24 only)
# TMUX_USE_I420=0
# VideoSource is_screencast (default 0; matches browsing_agent browser track)
# TMUX_SCREENCAST=0
# TMUX_FONT_PATH=/System/Library/Fonts/Menlo.ttc
